{
  "manifest_version": 2,
  "name": "Madoka Scanner",
  "version": "1.3",
  "description": "Analiza archivos descargados con Google Magika IA",
  "permissions": [
    "downloads",
    "notifications",
    "storage",
    "tabs",
    "http://localhost:5050/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "madoka-scanner@madoka",
      "strict_min_version": "91.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_title": "Madoka Scanner",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
