{
  "manifest_version": 3,
  "name": "Madoka Scanner",
  "version": "1.3",
  "description": "Analiza archivos descargados con Google Magika IA",
  "permissions": [
    "downloads",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5050/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Madoka Scanner",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
